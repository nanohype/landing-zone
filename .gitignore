# OpenTofu
.terraform/
# .terraform.lock.hcl: track the canonical per-root locks (reproducible, hash-pinned
# provider resolution) under components/ and fleet/; ignore the derived copies that
# terragrunt leaves in live/ working dirs and module test dirs.
.terraform.lock.hcl
!/components/aws/*/.terraform.lock.hcl
!/fleet/aws/*/.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfplan
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terragrunt
.terragrunt-cache/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
